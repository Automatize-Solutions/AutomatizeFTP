<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AutomatizeFTP.Presentation.Avalonia.Views.CreateFolderView"
             x:CompileBindings="False"
             xmlns:designTime="clr-namespace:AutomatizeFTP.Presentation.DesignTime;assembly=AutomatizeFTP.Presentation"
             Background="{DynamicResource SurfaceBrush}"
             Padding="20">
    <Design.DataContext>
        <designTime:DesignTimeCreateFolderViewModel />
    </Design.DataContext>
    <StackPanel VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Width="300">
        <TextBlock Text="{DynamicResource CreateFolder}"
                   Classes="Heading"
                   Margin="0 10" />
        <ProgressBar HorizontalAlignment="Stretch"
                     IsIndeterminate="{Binding IsLoading}"
                     IsVisible="{Binding IsLoading}"
                     Margin="0 5" />
        <StackPanel IsVisible="{Binding HasErrorMessage}"
                    Background="{DynamicResource ErrorSurfaceBrush}"
                    Margin="0 0 0 5">
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="{DynamicResource ErrorTextBrush}"
                       TextWrapping="Wrap"
                       Margin="10" />
        </StackPanel>
        <StackPanel Orientation="Horizontal" Margin="0 5">
            <TextBlock Text="{DynamicResource CreatingFolderAt}" Margin="0 0 5 0" />
            <TextBlock Text="{Binding Path}" Opacity="0.5" />
        </StackPanel>
        <TextBlock Text="{DynamicResource FolderNamePrompt}" Margin="0 5" />
        <TextBox PlaceholderText="{DynamicResource FolderNamePlaceholder}" Text="{Binding Name, Mode=TwoWay}" />
        <Grid ColumnDefinitions="3*,2*">
            <Button Grid.Column="0" Classes="primaryAction"
                    Content="{DynamicResource CreateFolder}"
                    HorizontalAlignment="Stretch"
                    Command="{Binding Create}"
                    Margin="0 10 10 10" />
            <Button Grid.Column="1" Classes="secondaryAction"
                    Content="{DynamicResource Close}"
                    HorizontalAlignment="Stretch"
                    Command="{Binding Close}"
                    Margin="0 10" />
        </Grid>
    </StackPanel>
</UserControl>
