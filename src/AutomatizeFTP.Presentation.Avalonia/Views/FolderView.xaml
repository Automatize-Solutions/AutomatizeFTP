<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:designTime="clr-namespace:AutomatizeFTP.Presentation.DesignTime;assembly=AutomatizeFTP.Presentation"
             x:Class="AutomatizeFTP.Presentation.Avalonia.Views.FolderView"
             x:CompileBindings="False"
             Background="Transparent">
    <Design.DataContext>
        <designTime:DesignTimeFolderViewModel />
    </Design.DataContext>
    <UserControl.Styles>
      <Style Selector="Button">
        <Setter Property="Margin" Value="0"/>
        <Setter Property="Padding" Value="7,5"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
      </Style>
      <Style Selector="Button.breadcrumb">
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="FontSize" Value="12" />
      </Style>
      <Style Selector="Button.breadcrumb:pointerover">
        <Setter Property="Background" Value="{DynamicResource AccentSurfaceBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
      </Style>
      <Style Selector="Button.breadcrumb:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource AccentSurfaceBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
      </Style>
      <Style Selector="TextBlock">
        <Setter Property="VerticalAlignment" Value="Center"/>
      </Style>
    </UserControl.Styles>
    <Grid>
      <StackPanel Orientation="Horizontal">
        <Button Classes="breadcrumb"
                Command="{Binding Provider.SetPath}"
                CommandParameter="{Binding FullPath}"
                ToolTip.Tip="{Binding FullPath}">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBlock Text="▰" Foreground="{DynamicResource AccentBrush}" />
            <TextBlock Text="{Binding Name}" />
          </StackPanel>
        </Button>
        <TextBlock Text="›"
                   FontSize="18"
                   Foreground="{DynamicResource AccentBrush}"
                   Opacity="0.65"
                   Margin="3,0,3,0" />
      </StackPanel>
    </Grid>
</UserControl>
