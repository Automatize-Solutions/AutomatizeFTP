<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:interfaces="clr-namespace:AutomatizeFTP.Presentation.Interfaces;assembly=AutomatizeFTP.Presentation"
    xmlns:views="clr-namespace:AutomatizeFTP.Presentation.Avalonia.Views"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:designTime="clr-namespace:AutomatizeFTP.Presentation.DesignTime;assembly=AutomatizeFTP.Presentation"
    x:Class="AutomatizeFTP.Presentation.Avalonia.Views.MainView"
    x:CompileBindings="False"
    MinHeight="680" MinWidth="1180"
    FontFamily="Segoe UI, Ubuntu">
    <Design.DataContext>
        <designTime:DesignTimeMainViewModel />
    </Design.DataContext>
    <UserControl.Styles>
        <Style Selector="Button">
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="CornerRadius" Value="7" />
        </Style>
        <Style Selector="Button.ghost">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
        </Style>
        <Style Selector="Button.ghost:pointerover">
            <Setter Property="Background" Value="{DynamicResource HoverSurfaceBrush}" />
        </Style>
        <Style Selector="Button.accent">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
        </Style>
        <Style Selector="Button.accent:pointerover">
            <Setter Property="Background" Value="{DynamicResource AccentHoverBrush}" />
        </Style>
        <Style Selector="ComboBox.workspaceSelector">
            <Setter Property="Background" Value="{DynamicResource SurfaceSubtleBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            <Setter Property="Padding" Value="10,7" />
        </Style>
        <Style Selector="ComboBox.workspaceSelector:pointerover">
            <Setter Property="Background" Value="{DynamicResource HoverSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        </Style>
        <Style Selector="ComboBox.workspaceSelector:focus">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        </Style>
        <Style Selector="ComboBox.workspaceSelector /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        </Style>
        <Style Selector="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
        <Style Selector="GridSplitter">
            <Setter Property="Background" Value="{DynamicResource BorderBrush}" />
        </Style>
        <Style Selector="GridSplitter:pointerover">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
        </Style>
    </UserControl.Styles>

    <Grid Background="{DynamicResource AppBackgroundBrush}" RowDefinitions="64,68,*,5,190">
        <!-- Application header -->
        <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="Auto,*,Auto" Margin="24,0">
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="34" Height="34" CornerRadius="10" Background="{DynamicResource AccentSurfaceBrush}">
                        <TextBlock Text="↔" Foreground="{DynamicResource AccentBrush}" FontSize="22"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="{DynamicResource AppName}" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                        <TextBlock Text="{DynamicResource AppSubtitle}" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextMutedBrush}" LetterSpacing="1.2" />
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="18,0,0,0">
                    <Button x:Name="LanguageButton" Classes="ghost" Content="{DynamicResource LanguageButton}" />
                    <Button x:Name="SwitchThemeButton" Classes="ghost"
                            Content="{DynamicResource Theme}" Margin="6,0,0,0" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="20,0">
            <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">
                    <TextBlock Text="{DynamicResource WorkspaceLabel}" FontSize="11" FontWeight="Bold"
                               Foreground="{DynamicResource TextMutedBrush}" LetterSpacing="1" />
                    <TextBlock Text="{DynamicResource SelectConnection}" FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="12,0,0,0" />
                </StackPanel>
                <ComboBox Grid.Column="1" Classes="workspaceSelector" Width="300"
                          ItemsSource="{Binding Clouds, Mode=OneWay}"
                          SelectedItem="{Binding SelectedProvider, Mode=TwoWay}"
                          PlaceholderText="{DynamicResource SelectConnection}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate DataType="interfaces:ICloudViewModel">
                            <TextBlock Text="{Binding Name}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="10,0,0,0">
                    <TextBlock Text="{DynamicResource Protocol}" Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <ComboBox Classes="workspaceSelector" Width="100"
                              ItemsSource="{Binding SupportedTypes, Mode=OneWay}"
                              SelectedItem="{Binding SelectedSupportedType, Mode=TwoWay}" />
                </StackPanel>
                <Button Grid.Column="3" Classes="accent" Content="{DynamicResource AddConnection}"
                        Command="{Binding Add}" Margin="10,0,0,0" />
                <Button Grid.Column="4" Classes="ghost" Content="{DynamicResource RemoveConnection}"
                        Command="{Binding Remove}" Margin="8,0,0,0" />
                <ProgressBar Grid.Column="5" Width="90" Height="3" IsIndeterminate="{Binding IsLoading}"
                             IsVisible="{Binding IsLoading}" Foreground="{DynamicResource AccentBrush}" Margin="16,0,0,0" />
            </Grid>
        </Border>

        <Grid Grid.Row="2" ColumnDefinitions="*,13,*" Background="{DynamicResource AppBackgroundBrush}">
            <Border Grid.Column="0" Background="{DynamicResource AppBackgroundBrush}">
                <views:LocalFilesView DataContext="{Binding LocalProvider, Mode=OneWay}" />
            </Border>

            <GridSplitter Grid.Column="1" Width="5" Margin="4,0" ResizeDirection="Columns" ResizeBehavior="PreviousAndNext"
                          HorizontalAlignment="Center" VerticalAlignment="Stretch" />

            <Border Grid.Column="2" Background="{DynamicResource AppBackgroundBrush}">
                <Grid>
                    <TransitioningContentControl IsVisible="{Binding WelcomeScreenCollapsed, Mode=OneWay}">
                        <TransitioningContentControl.PageTransition>
                            <CrossFade Duration="0.25" />
                        </TransitioningContentControl.PageTransition>
                        <TransitioningContentControl.Content>
                            <views:ProviderView DataContext="{Binding SelectedProvider, Mode=OneWay}" />
                        </TransitioningContentControl.Content>
                    </TransitioningContentControl>
                    <Grid IsVisible="{Binding WelcomeScreenVisible, Mode=OneWay}">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="300">
                            <Border Width="64" Height="64" CornerRadius="18" Background="{DynamicResource AccentSurfaceBrush}"
                                    HorizontalAlignment="Center">
                                <TextBlock Text="↔" Foreground="{DynamicResource AccentBrush}" FontSize="36"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Text="{DynamicResource WorkspaceTitle}" FontSize="20" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center" Margin="0,18,0,8" />
                            <TextBlock Text="{DynamicResource WorkspaceText}" TextWrapping="Wrap" TextAlignment="Center"
                                       Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" />
                            <Button Content="{DynamicResource AddConnection}" Classes="accent" Command="{Binding Add}"
                                    HorizontalAlignment="Center" Margin="0,18,0,0" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <GridSplitter Grid.Row="3" Height="5" ResizeDirection="Rows" ResizeBehavior="PreviousAndNext"
                      HorizontalAlignment="Stretch" VerticalAlignment="Center" />

        <Border Grid.Row="4" Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="9"
                Margin="16,0,16,12">
            <TabControl>
                <TabItem Header="{DynamicResource TransferQueue}">
                    <Grid RowDefinitions="Auto,*" Margin="16,12">
                        <Grid ColumnDefinitions="*,Auto">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{DynamicResource TransferQueue}" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}" />
                                <Border Background="{DynamicResource AccentSurfaceBrush}" CornerRadius="9" Padding="7,2" Margin="8,0,0,0">
                                    <TextBlock Text="{Binding TransferQueue.ActiveCount}" Foreground="{DynamicResource AccentBrush}" FontSize="10" />
                                </Border>
                            </StackPanel>
                            <TextBlock Grid.Column="1" Text="{DynamicResource TransferQueueHint}"
                                       Foreground="{DynamicResource TextMutedBrush}" FontSize="11" />
                        </Grid>
                        <Grid Grid.Row="1">
                            <ItemsControl ItemsSource="{Binding TransferQueue.Active}"
                                          IsVisible="{Binding TransferQueue.HasActiveItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnDefinitions="2*,Auto,3*,3*" Margin="0,6">
                                            <TextBlock Text="{Binding Name}" Foreground="{DynamicResource TextPrimaryBrush}" />
                                            <TextBlock Grid.Column="1" Text="{Binding Operation}" Foreground="{DynamicResource AccentBrush}" Margin="12,0" />
                                            <TextBlock Grid.Column="2" Text="{Binding Source}" Foreground="{DynamicResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Grid.Column="3" Text="{Binding Destination}" Foreground="{DynamicResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis" Margin="12,0,0,0" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Text="{DynamicResource TransfersEmpty}"
                                       IsVisible="{Binding TransferQueue.HasNoActiveItems}"
                                       Foreground="{DynamicResource TextMutedBrush}" FontSize="11" VerticalAlignment="Center" />
                        </Grid>
                    </Grid>
                </TabItem>
                <TabItem Header="{DynamicResource FailedTransfers}">
                    <Grid Margin="16,12">
                        <ItemsControl ItemsSource="{Binding TransferQueue.Failed}"
                                      IsVisible="{Binding TransferQueue.HasFailedItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="2*,Auto,*" Margin="0,6">
                                        <TextBlock Text="{Binding Name}" Foreground="{DynamicResource TextPrimaryBrush}" />
                                        <TextBlock Grid.Column="1" Text="{Binding Status}" Foreground="{DynamicResource DangerBrush}" Margin="12,0" />
                                        <TextBlock Grid.Column="2" Text="{Binding ErrorMessage}" Foreground="{DynamicResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="{DynamicResource FailedTransfersEmpty}"
                                   IsVisible="{Binding TransferQueue.HasNoFailedItems}"
                                   Foreground="{DynamicResource TextMutedBrush}" FontSize="11" VerticalAlignment="Center" />
                    </Grid>
                </TabItem>
                <TabItem Header="{DynamicResource SuccessfulTransfers}">
                    <Grid Margin="16,12">
                        <ItemsControl ItemsSource="{Binding TransferQueue.Completed}"
                                      IsVisible="{Binding TransferQueue.HasCompletedItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnDefinitions="2*,Auto,3*,3*" Margin="0,6">
                                        <TextBlock Text="{Binding Name}" Foreground="{DynamicResource TextPrimaryBrush}" />
                                        <TextBlock Grid.Column="1" Text="{Binding Status}" Foreground="{DynamicResource SuccessBrush}" Margin="12,0" />
                                        <TextBlock Grid.Column="2" Text="{Binding Source}" Foreground="{DynamicResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Column="3" Text="{Binding Destination}" Foreground="{DynamicResource TextSecondaryBrush}" TextTrimming="CharacterEllipsis" Margin="12,0,0,0" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="{DynamicResource SuccessfulTransfersEmpty}"
                                   IsVisible="{Binding TransferQueue.HasNoCompletedItems}"
                                   Foreground="{DynamicResource TextMutedBrush}" FontSize="11" VerticalAlignment="Center" />
                    </Grid>
                </TabItem>
            </TabControl>
        </Border>
    </Grid>
</UserControl>
