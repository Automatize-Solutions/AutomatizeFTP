<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:designTime="clr-namespace:AutomatizeFTP.Presentation.DesignTime;assembly=AutomatizeFTP.Presentation"
             x:Class="AutomatizeFTP.Presentation.Avalonia.Views.HostAuthView"
             x:CompileBindings="False"
             Background="{DynamicResource SurfaceBrush}"
             Padding="20">
    <Design.DataContext>
        <designTime:DesignTimeHostAuthViewModel />
    </Design.DataContext>
    <StackPanel VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Width="300">
        <TextBlock Text="{DynamicResource RemoteHostAuth}"
                   Classes="Heading"
                   FontSize="16"
                   Margin="0,0,0,12" />
        <ProgressBar HorizontalAlignment="Stretch"
                     IsIndeterminate="{Binding IsBusy}"
                     IsVisible="{Binding IsBusy}"
                                         Margin="0,0,0,12" />
        <StackPanel IsVisible="{Binding HasErrorMessage}"
                    Background="{DynamicResource ErrorSurfaceBrush}"
                Margin="0,0,0,14">
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="{DynamicResource ErrorTextBrush}"
                       TextWrapping="Wrap"
                   Margin="10,8" />
        </StackPanel>
        <TextBlock Text="{DynamicResource AddressPrompt}"
               FontSize="14"
               Margin="0,0,0,6" />
        <Grid ColumnDefinitions="*,72" ColumnSpacing="10">
            <TextBox Grid.Column="0"
                 FontSize="14"
                 PlaceholderText="{DynamicResource AddressPlaceholder}"
                 Text="{Binding Address, Mode=TwoWay}" />
            <TextBox Grid.Column="1"
                 FontSize="14"
                 PlaceholderText="{DynamicResource PortPlaceholder}"
                 Text="{Binding Port, Mode=TwoWay}" />
        </Grid>
        <TextBlock x:Name="AddressValidation"
                   Foreground="{DynamicResource ErrorBrush}"
               TextWrapping="Wrap"
                   Margin="0,2,0,0" />
        <TextBlock x:Name="PortValidation"
                   Foreground="{DynamicResource ErrorBrush}"
               TextWrapping="Wrap"
                   Margin="0,2,0,0" />
        <TextBlock Text="{DynamicResource UsernamePrompt}"
               FontSize="14"
                   Margin="0,10,0,5" />
        <TextBox FontSize="14"
             PlaceholderText="{DynamicResource UsernamePlaceholder}"
             Text="{Binding Username, Mode=TwoWay}" />
        <TextBlock x:Name="UsernameValidation"
                   Foreground="{DynamicResource ErrorBrush}"
               TextWrapping="Wrap"
                   Margin="0,2,0,0" />
        <TextBlock Text="{DynamicResource PasswordPrompt}"
               FontSize="14"
                   Margin="0,10,0,5" />
        <TextBox FontSize="14"
             Text="{Binding Password, Mode=TwoWay}"
             PlaceholderText="{DynamicResource PasswordPlaceholder}"
             PasswordChar="*" />
        <TextBlock x:Name="PasswordValidation"
                   Foreground="{DynamicResource ErrorBrush}"
               TextWrapping="Wrap"
                   Margin="0,2,0,0" />
        <Button Classes="primaryAction" Content="{DynamicResource Login}"
                HorizontalAlignment="Stretch"
                Command="{Binding Login}"
            Height="36"
            FontSize="14"
                Margin="0,12,0,0" />
        <TextBlock x:Name="FormValidation"
                   Foreground="{DynamicResource ErrorBrush}"
                   TextWrapping="Wrap" />
    </StackPanel>
</UserControl>
