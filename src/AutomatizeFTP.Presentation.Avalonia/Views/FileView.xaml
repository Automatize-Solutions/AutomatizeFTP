<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:designTime="clr-namespace:AutomatizeFTP.Presentation.DesignTime;assembly=AutomatizeFTP.Presentation"
             x:Class="AutomatizeFTP.Presentation.Avalonia.Views.FileView"
             x:CompileBindings="False"
             Background="Transparent">
    <Design.DataContext>
        <designTime:DesignTimeFileViewModel />
    </Design.DataContext>
    <UserControl.ContextMenu>
        <ContextMenu>
            <MenuItem Header="{DynamicResource Open}" Command="{Binding Provider.Open}" />
            <MenuItem Header="{DynamicResource Download}" Command="{Binding Provider.DownloadSelectedFile}" />
            <MenuItem Header="{DynamicResource Rename}" Command="{Binding Provider.Rename.Open}" />
            <MenuItem Header="{DynamicResource Unselect}" Command="{Binding Provider.UnselectFile}" />
        </ContextMenu>
    </UserControl.ContextMenu>
    <Grid MinHeight="48" Margin="14,0" ColumnDefinitions="28,*,100,90,110">
        <Border Grid.Column="0" Width="28" Height="28" CornerRadius="7" Background="{DynamicResource FolderSurfaceBrush}"
                IsVisible="{Binding IsFolder}" VerticalAlignment="Center">
            <TextBlock Text="▰" Foreground="{DynamicResource FolderBrush}" FontSize="13"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>
        <Border Grid.Column="0" Width="28" Height="28" CornerRadius="7" Background="{DynamicResource AccentSurfaceBrush}"
                IsVisible="{Binding IsFile}" VerticalAlignment="Center">
            <TextBlock Text="▤" Foreground="{DynamicResource AccentBrush}" FontSize="15"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>
        <TextBlock Grid.Column="1" Text="{Binding Name}" Foreground="{DynamicResource TextPrimaryBrush}" FontSize="12"
                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis" Margin="10,0,8,0" />
        <TextBlock Grid.Column="2" Text="{DynamicResource Folder}" IsVisible="{Binding IsFolder}"
                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" VerticalAlignment="Center" />
        <TextBlock Grid.Column="2" Text="{DynamicResource File}" IsVisible="{Binding IsFile}"
                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" VerticalAlignment="Center" />
        <TextBlock Grid.Column="3" Text="{Binding Size}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"
                   VerticalAlignment="Center" />
        <TextBlock Grid.Column="4" Text="{Binding Modified}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"
                   VerticalAlignment="Center" />
    </Grid>
</UserControl>
