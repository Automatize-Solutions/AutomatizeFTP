<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:AutomatizeFTP.Presentation.Avalonia.Views"
             xmlns:controls="clr-namespace:AutomatizeFTP.Presentation.Avalonia.Controls"
             xmlns:interfaces="clr-namespace:AutomatizeFTP.Presentation.Interfaces;assembly=AutomatizeFTP.Presentation"
             xmlns:designTime="clr-namespace:AutomatizeFTP.Presentation.DesignTime;assembly=AutomatizeFTP.Presentation"
             x:Class="AutomatizeFTP.Presentation.Avalonia.Views.ProviderView"
             x:CompileBindings="False">
    <Design.DataContext>
        <designTime:DesignTimeCloudViewModel />
    </Design.DataContext>
    <UserControl.Resources>
        <ControlTheme x:Key="BreadcrumbItemTheme" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <ControlTemplate>
                    <ContentPresenter Name="PART_ContentPresenter"
                                      Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                      Padding="{TemplateBinding Padding}"
                                      HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                      Background="{TemplateBinding Background}"
                                      BorderBrush="{TemplateBinding BorderBrush}"
                                      BorderThickness="{TemplateBinding BorderThickness}"
                                      CornerRadius="{TemplateBinding CornerRadius}" />
                </ControlTemplate>
            </Setter>
            <Style Selector="^:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            </Style>
        </ControlTheme>
        <ControlTheme x:Key="FileItemTheme" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <ControlTemplate>
                    <ContentPresenter Name="PART_ContentPresenter"
                                      Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                      Padding="{TemplateBinding Padding}"
                                      HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                      Background="{TemplateBinding Background}"
                                      BorderBrush="{TemplateBinding BorderBrush}"
                                      BorderThickness="{TemplateBinding BorderThickness}"
                                      CornerRadius="{TemplateBinding CornerRadius}" />
                </ControlTemplate>
            </Setter>
            <Style Selector="^:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                <Setter Property="Background" Value="{DynamicResource HoverSurfaceBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            </Style>
            <Style Selector="^:selected /template/ ContentPresenter#PART_ContentPresenter">
                <Setter Property="Background" Value="{DynamicResource AccentSurfaceBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            </Style>
            <Style Selector="^:selected">
                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                <Setter Property="BorderThickness" Value="3,0,0,0" />
            </Style>
            <Style Selector="^:selected:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                <Setter Property="Background" Value="{DynamicResource AccentSurfaceBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
            </Style>
            <Style Selector="^:selected:pointerover">
                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                <Setter Property="BorderThickness" Value="3,0,0,0" />
            </Style>
        </ControlTheme>
    </UserControl.Resources>
    <UserControl.Styles>
        <Style Selector="Button">
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="CornerRadius" Value="7" />
        </Style>
        <Style Selector="Button.icon">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="32" />
        </Style>
        <Style Selector="Button.action">
            <Setter Property="Background" Value="{DynamicResource SurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        </Style>
        <Style Selector="Button.primaryAction">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}" />
        </Style>
        <Style Selector="Button.action:pointerover">
            <Setter Property="Background" Value="{DynamicResource HoverSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
        </Style>
        <Style Selector="Button.primaryAction:pointerover">
            <Setter Property="Background" Value="{DynamicResource AccentHoverBrush}" />
        </Style>
        <Style Selector="ListBox.BreadCrumb">
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Hidden" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Hidden" />
            <Setter Property="ItemsPanel">
                <Setter.Value>
                    <ItemsPanelTemplate><StackPanel Orientation="Horizontal" /></ItemsPanelTemplate>
                </Setter.Value>
            </Setter>
            <Setter Property="ItemTemplate">
                <Setter.Value>
                    <DataTemplate DataType="interfaces:IFolderViewModel">
                        <views:FolderView DataContext="{Binding}" />
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Styles>

    <Grid Margin="0,18,16,16">
    <Grid RowDefinitions="Auto,Auto,*">
        <!-- Provider title -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="2,0,2,18">
            <StackPanel>
                <TextBlock Text="{Binding Name}" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                    <Ellipse Width="7" Height="7" Fill="{DynamicResource SuccessBrush}" VerticalAlignment="Center" />
                    <TextBlock Text="{DynamicResource Connected}" Foreground="{DynamicResource SuccessBrush}" FontSize="11" Margin="7,0,12,0" />
                    <TextBlock Text="{Binding Description}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="11" />
                </StackPanel>
            </StackPanel>
            <Button Grid.Column="1" Classes="action" Content="{DynamicResource Disconnect}"
                    IsVisible="{Binding CanLogout}" Command="{Binding Logout}" VerticalAlignment="Center" />
        </Grid>

        <!-- Navigation and path -->
        <Grid Grid.Row="1" ColumnDefinitions="Auto,*,Auto" Margin="0,0,0,12">
            <Button Grid.Column="0" Classes="icon" Content="‹" FontSize="24"
                    Command="{Binding Back}" ToolTip.Tip="{DynamicResource BackTooltip}" />
            <Border Grid.Column="1" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    CornerRadius="7" Margin="8,0" Padding="8,0">
                <Grid>
                    <TextBlock Text="{Binding CurrentPath}" IsVisible="{Binding HideBreadCrumbs}"
                               Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center" FontSize="12" />
                    <ListBox ItemsSource="{Binding BreadCrumbs}" Classes="BreadCrumb"
                             ItemContainerTheme="{StaticResource BreadcrumbItemTheme}"
                             IsVisible="{Binding ShowBreadCrumbs}" Padding="0" />
                </Grid>
            </Border>
            <Button Grid.Column="2" Classes="icon" Content="↻" FontSize="18"
                    Command="{Binding Refresh}" ToolTip.Tip="{DynamicResource RefreshTooltip}" />
        </Grid>

        <!-- File browser -->
        <Border Grid.Row="2" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="9">
            <Grid RowDefinitions="38,*">
                <Border Grid.Row="0" Background="{DynamicResource SurfaceSubtleBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                        CornerRadius="9,9,0,0" Padding="14,0">
                    <Grid ColumnDefinitions="28,*,110,110,150" ColumnSpacing="10">
                        <TextBlock Grid.Column="0" Text="" />
                        <TextBlock Grid.Column="1" Text="{DynamicResource Name}" FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource TextMutedBrush}" Margin="10,0,8,0"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2" Text="{DynamicResource Type}" FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource TextMutedBrush}" Margin="10,0,8,0"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="3" Text="{DynamicResource Size}" FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Stretch"
                                   TextAlignment="Right" Margin="0,0,10,0" VerticalAlignment="Center" />
                        <TextBlock Grid.Column="4" Text="{DynamicResource Modified}" FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource TextMutedBrush}" HorizontalAlignment="Stretch"
                                   TextAlignment="Right" Margin="0,0,10,0" VerticalAlignment="Center" />
                    </Grid>
                </Border>
                <Grid Grid.Row="1">
                    <controls:FileExplorerListBox x:Name="FilesList" Classes="files" Padding="0" ItemsSource="{Binding Files}"
                             ItemContainerTheme="{StaticResource FileItemTheme}"
                             IsVisible="{Binding IsReady}" ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                             SelectionMode="Multiple" Focusable="True" Background="Transparent">
                        <controls:FileExplorerListBox.ContextMenu>
                            <ContextMenu>
                                <MenuItem x:Name="CreateFolderMenuItem" Header="{DynamicResource CreateFolder}">
                                    <MenuItem.Icon>
                                        <TextBlock Text="▰" Width="16" HorizontalAlignment="Center" />
                                    </MenuItem.Icon>
                                </MenuItem>
                                <MenuItem x:Name="CreateFolderAndEnterMenuItem" Header="{DynamicResource CreateFolderAndEnter}">
                                    <MenuItem.Icon>
                                        <TextBlock Text="↳" Width="16" HorizontalAlignment="Center" />
                                    </MenuItem.Icon>
                                </MenuItem>
                            </ContextMenu>
                        </controls:FileExplorerListBox.ContextMenu>
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="interfaces:IFileViewModel">
                                <views:FileView DataContext="{Binding}" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </controls:FileExplorerListBox>
                    <StackPanel IsVisible="{Binding IsLoading}" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10">
                        <ProgressBar Width="220" IsIndeterminate="True" />
                        <TextBlock Text="{DynamicResource LoadingFiles}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" />
                    </StackPanel>
                    <StackPanel IsVisible="{Binding IsCurrentPathEmpty}" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="7">
                        <TextBlock Text="{DynamicResource EmptyFolder}" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="{DynamicResource EmptyFolderText}" Foreground="{DynamicResource TextMutedBrush}" FontSize="12" />
                    </StackPanel>
                    <StackPanel IsVisible="{Binding HasErrorMessage}" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="7">
                        <TextBlock Text="{DynamicResource LoadError}" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{DynamicResource DangerBrush}" HorizontalAlignment="Center" />
                        <TextBlock Text="{Binding ErrorMessage}" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"
                                   MaxWidth="360" TextWrapping="Wrap" TextAlignment="Center" />
                    </StackPanel>
                    <Grid IsVisible="{Binding Folder.IsVisible}" Background="{DynamicResource SurfaceBrush}">
                        <views:CreateFolderView DataContext="{Binding Folder}" />
                    </Grid>
                    <Grid IsVisible="{Binding Rename.IsVisible}" Background="{DynamicResource SurfaceBrush}">
                        <views:RenameFileView DataContext="{Binding Rename}" />
                    </Grid>
                </Grid>
            </Grid>
        </Border>

      </Grid>

      <Grid IsVisible="{Binding Auth.IsAnonymous}" Background="{DynamicResource AppBackgroundBrush}">
        <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="12"
                Width="420" Height="460" HorizontalAlignment="Center" VerticalAlignment="Center">
            <views:AuthView DataContext="{Binding Auth}" />
        </Border>
      </Grid>
    </Grid>
</UserControl>
