<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <SolidColorBrush x:Key="AppBackgroundBrush" Color="#E9EEF5" />
  <SolidColorBrush x:Key="SurfaceBrush" Color="#F6F8FB" />
  <SolidColorBrush x:Key="SurfaceSubtleBrush" Color="#EEF2F7" />
  <SolidColorBrush x:Key="HoverSurfaceBrush" Color="#E0E8F4" />
  <SolidColorBrush x:Key="BorderBrush" Color="#CBD5E1" />
  <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1E293B" />
  <SolidColorBrush x:Key="TextSecondaryBrush" Color="#475569" />
  <SolidColorBrush x:Key="TextMutedBrush" Color="#718096" />
  <SolidColorBrush x:Key="AccentBrush" Color="#526FAE" />
  <SolidColorBrush x:Key="AccentHoverBrush" Color="#405D99" />
  <SolidColorBrush x:Key="AccentSurfaceBrush" Color="#D8E2F2" />
  <SolidColorBrush x:Key="AccentTextBrush" Color="#FFFFFF" />
  <SolidColorBrush x:Key="SuccessBrush" Color="#22C55E" />
  <SolidColorBrush x:Key="DangerBrush" Color="#B91C1C" />
  <SolidColorBrush x:Key="ErrorSurfaceBrush" Color="#FFEEEE" />
  <SolidColorBrush x:Key="ErrorTextBrush" Color="#990000" />
  <SolidColorBrush x:Key="ErrorBrush" Color="#B91C1C" />
  <SolidColorBrush x:Key="FolderSurfaceBrush" Color="#FFF7D6" />
  <SolidColorBrush x:Key="FolderBrush" Color="#D97706" />
</ResourceDictionary>
