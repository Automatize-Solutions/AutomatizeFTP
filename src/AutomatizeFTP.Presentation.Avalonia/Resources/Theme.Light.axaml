<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <SolidColorBrush x:Key="AppBackgroundBrush" Color="#F4F7FB" />
  <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF" />
  <SolidColorBrush x:Key="SurfaceSubtleBrush" Color="#F8FAFC" />
  <SolidColorBrush x:Key="HoverSurfaceBrush" Color="#EFF6FF" />
  <SolidColorBrush x:Key="BorderBrush" Color="#E2E8F0" />
  <SolidColorBrush x:Key="TextPrimaryBrush" Color="#0F172A" />
  <SolidColorBrush x:Key="TextSecondaryBrush" Color="#475569" />
  <SolidColorBrush x:Key="TextMutedBrush" Color="#94A3B8" />
  <SolidColorBrush x:Key="SidebarBrush" Color="#111827" />
  <SolidColorBrush x:Key="SidebarSurfaceBrush" Color="#1F2937" />
  <SolidColorBrush x:Key="SidebarTextBrush" Color="#F8FAFC" />
  <SolidColorBrush x:Key="SidebarMutedBrush" Color="#CBD5E1" />
  <SolidColorBrush x:Key="AccentBrush" Color="#2563EB" />
  <SolidColorBrush x:Key="AccentHoverBrush" Color="#1D4ED8" />
  <SolidColorBrush x:Key="AccentSurfaceBrush" Color="#E8F0FF" />
  <SolidColorBrush x:Key="AccentTextBrush" Color="#FFFFFF" />
  <SolidColorBrush x:Key="SuccessBrush" Color="#22C55E" />
  <SolidColorBrush x:Key="DangerBrush" Color="#B91C1C" />
  <SolidColorBrush x:Key="ErrorSurfaceBrush" Color="#FFEEEE" />
  <SolidColorBrush x:Key="ErrorTextBrush" Color="#990000" />
  <SolidColorBrush x:Key="ErrorBrush" Color="#B91C1C" />
  <SolidColorBrush x:Key="FolderSurfaceBrush" Color="#FFF7D6" />
  <SolidColorBrush x:Key="FolderBrush" Color="#D97706" />
</ResourceDictionary>
